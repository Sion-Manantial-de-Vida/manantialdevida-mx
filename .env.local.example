# ============================================================
#  PLANTILLA DE TOKENS  ·  Iglesia Sion Manantial de Vida
# ============================================================
# Este archivo SÍ se sube a GitHub (no tiene secretos reales).
# Sirve como guía de qué tokens necesitas.
#
# Para usarlo: copia este archivo como ".env.local" y pon ahí
# tus tokens REALES. El archivo ".env.local" NUNCA se sube
# (está protegido por .gitignore).
# ============================================================

# --- GitHub (acceso a repositorios) ---
GITHUB_TOKEN=ghp_pon_aqui_tu_token

# --- Herramientas futuras (déjalas listas para cuando las uses) ---
# VERCEL_TOKEN=
# RESEND_API_KEY=
# SENTRY_DSN=
# MERCADOPAGO_ACCESS_TOKEN=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
